<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="ImageVectorizer.MainWindow"
        Title="Image Vectorizer"
        Width="1200" Height="750"
        MinWidth="900" MinHeight="600"
        Background="#1A202C"
        WindowStartupLocation="CenterScreen">
    
    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>
        
        <!-- Main Image Area -->
        <Grid Grid.Column="0" Margin="0,0,20,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <!-- Header -->
            <TextBlock Grid.Row="0" Text="Image Vectorizer" 
                       FontSize="28" FontWeight="Bold" 
                       Foreground="#E2E8F0"
                       Margin="0,0,0,20"/>
            
            <!-- Image Panels -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <!-- Original Image Panel -->
                <Border Grid.Column="0" Classes="panel" Margin="0,0,10,0">
                    <Grid>
                        <TextBlock Text="Original Image" 
                                   Foreground="#E2E8F0"
                                   FontSize="12" FontWeight="SemiBold"
                                   Margin="15,10" VerticalAlignment="Top"/>
                        
                        <!-- Drop Zone -->
                        <Border x:Name="DropZone" Classes="dropzone" 
                                Margin="15,40,15,15"
                                DragDrop.AllowDrop="True">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="📁" FontSize="48" HorizontalAlignment="Center"/>
                                <TextBlock Text="Drag &amp; Drop Image Here" 
                                           Foreground="#E2E8F0"
                                           FontSize="16" Margin="0,10,0,5"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="or" Foreground="#718096" 
                                           HorizontalAlignment="Center"/>
                                <Button x:Name="BrowseButton" Content="Browse Files" 
                                        Classes="primary"
                                        Margin="0,10,0,0"
                                        HorizontalAlignment="Center"/>
                                <TextBlock Text="PNG, JPG, BMP, GIF supported" 
                                           Foreground="#718096" FontSize="11"
                                           Margin="0,15,0,0"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        
                        <!-- Original Image Display -->
                        <Image x:Name="OriginalImage" 
                               Margin="15,40,15,15"
                               Stretch="Uniform"
                               IsVisible="False"/>
                    </Grid>
                </Border>
                
                <!-- Vectorized Image Panel -->
                <Border Grid.Column="1" Classes="panel" Margin="10,0,0,0">
                    <Grid>
                        <TextBlock Text="Vectorized Result" 
                                   Foreground="#E2E8F0"
                                   FontSize="12" FontWeight="SemiBold"
                                   Margin="15,10" VerticalAlignment="Top"/>
                        
                        <!-- Placeholder -->
                        <StackPanel x:Name="ResultPlaceholder"
                                    VerticalAlignment="Center" 
                                    HorizontalAlignment="Center">
                            <TextBlock Text="🎨" FontSize="48" HorizontalAlignment="Center"/>
                            <TextBlock Text="Vectorized image will appear here" 
                                       Foreground="#718096"
                                       FontSize="14" Margin="0,10,0,0"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                        
                        <!-- Result Image Display -->
                        <Image x:Name="ResultImage" 
                               Margin="15,40,15,15"
                               Stretch="Uniform"
                               IsVisible="False"/>
                    </Grid>
                </Border>
            </Grid>
            
            <!-- Progress Bar -->
            <Grid Grid.Row="2" Margin="0,15,0,0">
                <ProgressBar x:Name="ProcessingProgress" 
                             Height="6" 
                             Background="#4A5568"
                             Foreground="#4299E1"
                             IsVisible="False"
                             IsIndeterminate="True"/>
                <TextBlock x:Name="StatusText" 
                           Text="Ready" 
                           Foreground="#718096"
                           FontSize="12"
                           Margin="0,10,0,0"/>
            </Grid>
        </Grid>
        
        <!-- Settings Panel -->
        <Border Grid.Column="1" Classes="panel" Padding="20">
            <ScrollViewer>
                <StackPanel>
                    <TextBlock Text="Settings" 
                               FontSize="18" FontWeight="Bold"
                               Foreground="#E2E8F0"
                               Margin="0,0,0,20"/>
                    
                    <!-- Color Count -->
                    <TextBlock Text="Color Count" 
                               Foreground="#E2E8F0"
                               FontSize="13" FontWeight="SemiBold"/>
                    <TextBlock Text="Number of colors in the output"
                               Foreground="#718096" FontSize="11" Margin="0,2,0,8"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="50"/>
                        </Grid.ColumnDefinitions>
                        <Slider x:Name="ColorCountSlider" 
                                Minimum="2" Maximum="64" Value="16"
                                TickFrequency="1" IsSnapToTickEnabled="True"/>
                        <TextBlock Grid.Column="1" 
                                   Text="{Binding #ColorCountSlider.Value, StringFormat={}{0:0}}"
                                   Foreground="#4299E1"
                                   FontWeight="Bold" FontSize="14"
                                   HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>
                    
                    <Rectangle Fill="#4A5568" Height="1" Margin="0,15"/>
                    
                    <!-- Detail Level -->
                    <TextBlock Text="Detail Level" 
                               Foreground="#E2E8F0"
                               FontSize="13" FontWeight="SemiBold"/>
                    <TextBlock Text="Higher = more detail, larger file"
                               Foreground="#718096" FontSize="11" Margin="0,2,0,8"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="50"/>
                        </Grid.ColumnDefinitions>
                        <Slider x:Name="DetailSlider" 
                                Minimum="1" Maximum="10" Value="5"
                                TickFrequency="1" IsSnapToTickEnabled="True"/>
                        <TextBlock Grid.Column="1" 
                                   Text="{Binding #DetailSlider.Value, StringFormat={}{0:0}}"
                                   Foreground="#4299E1"
                                   FontWeight="Bold" FontSize="14"
                                   HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>
                    
                    <Rectangle Fill="#4A5568" Height="1" Margin="0,15"/>
                    
                    <!-- Edge Detection -->
                    <TextBlock Text="Edge Sensitivity" 
                               Foreground="#E2E8F0"
                               FontSize="13" FontWeight="SemiBold"/>
                    <TextBlock Text="How aggressively edges are detected"
                               Foreground="#718096" FontSize="11" Margin="0,2,0,8"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="50"/>
                        </Grid.ColumnDefinitions>
                        <Slider x:Name="EdgeSlider" 
                                Minimum="1" Maximum="10" Value="5"
                                TickFrequency="1" IsSnapToTickEnabled="True"/>
                        <TextBlock Grid.Column="1" 
                                   Text="{Binding #EdgeSlider.Value, StringFormat={}{0:0}}"
                                   Foreground="#4299E1"
                                   FontWeight="Bold" FontSize="14"
                                   HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>
                    
                    <Rectangle Fill="#4A5568" Height="1" Margin="0,15"/>
                    
                    <!-- Smoothing -->
                    <TextBlock Text="Path Smoothing" 
                               Foreground="#E2E8F0"
                               FontSize="13" FontWeight="SemiBold"/>
                    <TextBlock Text="Smoothness of vector curves"
                               Foreground="#718096" FontSize="11" Margin="0,2,0,8"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="50"/>
                        </Grid.ColumnDefinitions>
                        <Slider x:Name="SmoothingSlider" 
                                Minimum="0" Maximum="10" Value="3"
                                TickFrequency="1" IsSnapToTickEnabled="True"/>
                        <TextBlock Grid.Column="1" 
                                   Text="{Binding #SmoothingSlider.Value, StringFormat={}{0:0}}"
                                   Foreground="#4299E1"
                                   FontWeight="Bold" FontSize="14"
                                   HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>
                    
                    <Rectangle Fill="#4A5568" Height="1" Margin="0,15"/>
                    
                    <!-- Options -->
                    <TextBlock Text="Options" 
                               Foreground="#E2E8F0"
                               FontSize="13" FontWeight="SemiBold"
                               Margin="0,0,0,10"/>
                    
                    <CheckBox x:Name="PreserveTransparency" 
                              Content="Preserve transparency"
                              Foreground="#E2E8F0"
                              IsChecked="True" Margin="0,5"/>
                    
                    <CheckBox x:Name="AntiAliasing" 
                              Content="Anti-aliased edges"
                              Foreground="#E2E8F0"
                              IsChecked="True" Margin="0,5"/>
                    
                    <CheckBox x:Name="SimplifyPaths" 
                              Content="Simplify paths"
                              Foreground="#E2E8F0"
                              IsChecked="True" Margin="0,5"/>
                    
                    <Rectangle Fill="#4A5568" Height="1" Margin="0,20"/>
                    
                    <!-- Action Buttons -->
                    <Button x:Name="VectorizeButton"
                            Content="🚀 Vectorize"
                            Classes="primary"
                            IsEnabled="False"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"
                            Margin="0,0,0,10"/>
                    
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button x:Name="SaveSvgButton"
                                Content="Save SVG"
                                Classes="primary"
                                IsEnabled="False"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                Margin="0,0,5,0"/>
                        <Button x:Name="SavePngButton"
                                Grid.Column="1"
                                Content="Save PNG"
                                Classes="primary"
                                IsEnabled="False"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                Margin="5,0,0,0"/>
                    </Grid>
                    
                    <Button x:Name="SaveBothButton"
                            Content="💾 Save Both (SVG + PNG)"
                            Classes="primary"
                            IsEnabled="False"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"
                            Margin="0,10,0,0"/>
                    
                    <Rectangle Fill="#4A5568" Height="1" Margin="0,20"/>
                    
                    <!-- Reset -->
                    <Button x:Name="ResetButton" 
                            Content="🔄 Reset All"
                            Classes="secondary"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"/>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
